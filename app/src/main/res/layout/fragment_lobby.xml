<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hacker_black"
    android:padding="20dp">

    <!-- Top welcome bar -->
    <LinearLayout
        android:id="@+id/layout_welcome_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_welcome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Привет, Пилот!"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_peer_name"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_styled"
                    android:imeOptions="actionDone"
                    android:inputType="textCapSentences"
                    android:maxLength="18"
                    android:maxLines="1"
                    android:paddingHorizontal="10dp"
                    android:selectAllOnFocus="true"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:visibility="gone"
                    tools:text="Пилот"
                    tools:visibility="visible" />

                <ImageButton
                    android:id="@+id/btn_edit_name"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Редактировать имя"
                    android:padding="8dp"
                    android:src="@drawable/ic_edit"
                    app:tint="@color/second_accent_green" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Каналы активной радиосвязи"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <ImageView
            android:id="@+id/fr_lobby_users"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_users"
            android:contentDescription="Users Icon" />

    </LinearLayout>

    <TextView
        android:id="@+id/tv_lobby_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="#331F2937"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp"
        android:textColor="#F43F5E"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_welcome_header"
        tools:text="Нет Nearby permissions"
        tools:visibility="visible" />

    <!-- Main Active Rooms List Card -->
    <LinearLayout
        android:id="@+id/layout_rooms_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_card_border_styled"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_lobby_error"
        app:layout_constraintBottom_toTopOf="@id/btn_create_room"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="РАДИОЧАСТОТЫ В ЭФИРЕ"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="12dp" />

        <View
            android:id="@+id/view_scan_progress"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginBottom="10dp"
            android:background="@color/accent_green"
            android:scaleX="0"
            android:transformPivotX="0dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_rooms"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical"
            tools:listitem="@layout/item_room" />

    </LinearLayout>

    <!-- Bottom Create Room Button -->
    <Button
        android:id="@+id/btn_create_room"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_btn_green"
        android:text="Создать новый канал (+)"
        android:textColor="@color/hacker_black"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
